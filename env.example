# ── Twilio (Opción A - más fácil para empezar) ─────────────────────────────────
# Obtén estas credenciales en https://console.twilio.com
TWILIO_ACCOUNT_SID=HXb5b62575e6e4ff6129ad7c8efe1f983e
TWILIO_AUTH_TOKEN=ACca9de9299162af130d0b8729c4233d4a
TWILIO_WA_FROM=whatsapp:+14155238886

# ── Meta WhatsApp Business Cloud API (Opción B - producción oficial) ───────────
# Obtén estos datos en https://developers.facebook.com → WhatsApp
META_PHONE_ID=
META_ACCESS_TOKEN=

# ── Número de la clínica (destino de los mensajes) ─────────────────────────────
CLINICA_WA_NUMBER=+593958601411

# ── URL pública del servidor (necesaria para Twilio media URLs) ────────────────
# En desarrollo: usa ngrok → ngrok http 3001 → copia la URL https://xxxx.ngrok.io
# En producción: tu dominio real → https://api.jezreelvet.com
PUBLIC_BASE_URL=https://TU-NGROK-URL-AQUI.ngrok.io
